{
  "mcpServers": {
    "MyFiles": {
      "command": "/home/user/.nvm/versions/node/v24.14.0/bin/npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/home/user/ClaudeStuff/Desktop",
        "/home/user/ClaudeStuff/Downloads",
        "/home/user/ClaudeStuff/mcp-server"
      ]
    },
    "DocFind": {
      "command": "/home/user/.local/bin/uv",
      "args": [
        "run",
        "--frozen",
        "--with",
        "mcp[cli],beautifulsoup4",
        "mcp",
        "run",
        "/home/user/ClaudeStuff/mcp-server/main.py"
      ]
    },
"greenmail": {
